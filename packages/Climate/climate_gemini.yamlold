# --------------------------------------------------------------------------------
# Paquete de Climatización Inteligente v3.0
# Creado para el usuario Hernán
#
# Entidades requeridas:
#   - climate.aire_acondicionado
#   - sensor.sala_temp_interior
#   - person.hernan (con zonas 'home' y 'oficina')
#
# --------------------------------------------------------------------------------

# ================================================================================
# == HELPERS: Todos los controles para el Dashboard
# ================================================================================
# sensores y templates v1

template:

  - sensor:
      - name: "Sala - Estado AC"
        unique_id: sala_estado_ac
        state: >-
          {% set s = states('climate.aire_acondicionado') %}
          {{ 1 if s != 'off' else 0 }}
        attributes:
          estado_texto: "{{ states('climate.aire_acondicionado') }}"
          icon: >-
            {% set t = states.timer.ac_auto_off %}
            {% if t and t.state == 'active' %}mdi:brightness-5{% else %}mdi:brightness-4{% endif %}

  - sensor:
      - name: "Sala - Temp Interior"
        unique_id: sala_temp_interior
        unit_of_measurement: "°C"
        device_class: temperature
        state: >-
          {% set source = states('input_select.sensor_temp_fav') %}
          {% if source == 'Desde aire' %}
            {{ state_attr('climate.aire_acondicionado','current_temperature') }}
          {% elif source == 'Desde sensor' %}
            {{ states('sensor.temperature_sala') }}
          {% else %}
            {{ state_attr('climate.aire_acondicionado','current_temperature') }}
          {% endif %}

      - name: "Sala - Tendencia temperatura"
        unique_id: sala_temp_trend_text
        state: >-
          {% set trend = states('binary_sensor.sala_temp_trend') %}
          {% if trend == 'on' %}
            subiendo
          {% elif trend == 'off' %}
            bajando
          {% else %}
            estable
          {% endif %}
        icon: >-
          {% set trend = states('binary_sensor.sala_temp_trend') %}
          {% if trend == 'on' %}
            mdi:arrow-up
          {% elif trend == 'off' %}
            mdi:arrow-down
          {% else %}
            mdi:arrow-left-right
          {% endif %}

binary_sensor:
  - platform: trend
    sensors:
      sala_temp_trend:
        entity_id: sensor.sala_temp_interior
        friendly_name: "Tendencia temperatura sala"
        sample_duration: 300
        max_samples: 5
        min_gradient: 0.001
        device_class: heat

### _______________________________________________________________________
####

input_boolean:
  smart_climate:
    name: Activar Climatización Inteligente (General)
    icon: mdi:brain-cog-outline

  climatizacion_inteligente_activa:
    name: Termostato Automático por Temperatura
    icon: mdi:thermostat-auto
    
  temp_pre_enfriado_custom:
    name: Usar Temperatura de Pre-enfriado Personalizada
    icon: mdi:temperature-alert

  clima_failsafe_media_player:
    name: "Failsafe: Chequear si hay TV encendida"
    icon: mdi:television-pause
    initial: on

input_number:
  temp_superior_encendido:
    name: Temperatura Superior para Encender
    min: 20
    max: 35
    step: 0.5
    unit_of_measurement: "°C"
    icon: mdi:thermometer-chevron-up

  temp_inferior_apagado:
    name: Temperatura Inferior para Apagar
    min: 18
    max: 30
    step: 0.5
    unit_of_measurement: "°C"
    icon: mdi:thermometer-chevron-down

  delay_ausencia_minutos:
    name: Delay para Apagar por Ausencia
    min: 0
    max: 30
    step: 1
    unit_of_measurement: "min"
    icon: mdi:account-arrow-right-outline

  delay_oficina_minutos:
    name: Delay para Apagar al llegar a Oficina
    min: 0
    max: 20
    step: 1
    unit_of_measurement: "min"
    icon: mdi:office-building-clock

  temp_pre_enfriado_custom:
    name: Temperatura Límite de Pre-enfriado
    min: 20
    max: 35
    step: 0.5
    unit_of_measurement: "°C"
    icon: mdi:calendar-thermometer

  delay_control_manual_minutos:
    name: Minutos de Pausa por Control Manual
    min: 1
    max: 60
    step: 1
    unit_of_measurement: "min"
    icon: mdi:hand-front-right

  clima_turbo_threshold:
    name: Umbral Temperatura Turbo Cool
    min: 24
    max: 32
    step: 0.5
    unit_of_measurement: "°C"
    icon: mdi:thermometer-high

input_select:
  modo_clima:
    name: Modo de Operación del Clima
    options:
      - "Automático"
      - "Forzado Encendido"
      - "Forzado Apagado"
    initial: "Automático"
    icon: mdi:tune
    
  sensor_temp_fav:
    name: "Leer temperatura desde"
    options:
      - "Desde aire"
      - "Desde sensor"
    initial: "Desde aire"

input_datetime:
  clima_schedule_1:
    name: Horario Pre-enfriado 1
    has_date: false
    has_time: true
    icon: mdi:clock-start
  clima_schedule_2:
    name: Horario Pre-enfriado 2
    has_date: false
    has_time: true
    icon: mdi:clock-end

input_button:
  clima_trigger_turbo:
    name: Activar Turbo Cool Manual
    icon: mdi:rocket-launch


timer:
  clima_preset:
    name: Timer de Apagado Preset
    restore: true

  clima_failsafe_general:
    name: Timer Failsafe General (2 Horas)
    duration: '02:00:00'
    restore: true

  clima_control_manual:
    name: Timer de Pausa por Control Manual
    restore: true

# ================================================================================
# == SCRIPTS: Acciones reutilizables
# ================================================================================

script:
  # --- Scripts para los presets de tiempo ---
  clima_preset_20m:
    alias: "Clima: Iniciar preset de 20 minutos"
    icon: mdi:timer-sand
    sequence:
      - service: climate.turn_on
        target:
          entity_id: climate.aire_acondicionado
      - service: timer.start
        target:
          entity_id: timer.clima_preset
        data:
          duration: '00:20:00'

  clima_preset_40m:
    alias: "Clima: Iniciar preset de 40 minutos"
    icon: mdi:timer-sand
    sequence:
      - service: climate.turn_on
        target:
          entity_id: climate.aire_acondicionado
      - service: timer.start
        target:
          entity_id: timer.clima_preset
        data:
          duration: '00:40:00'

  clima_preset_1h:
    alias: "Clima: Iniciar preset de 1 hora"
    icon: mdi:timer-sand
    sequence:
      - service: climate.turn_on
        target:
          entity_id: climate.aire_acondicionado
      - service: timer.start
        target:
          entity_id: timer.clima_preset
        data:
          duration: '01:00:00'

  # --- Script centralizado para forzar el apagado ---
  clima_forzar_apagado:
    alias: "Clima: Forzar Apagado Total"
    icon: mdi:power-plug-off
    sequence:
      - service: climate.turn_off
        target:
          entity_id: climate.aire_acondicionado
      - service: timer.cancel
        target:
          entity_id: 
            - timer.clima_preset
            - timer.clima_failsafe_general
            - timer.clima_control_manual
      - service: input_boolean.turn_off
        target:
          entity_id: input_boolean.climatizacion_inteligente_activa

  add_hour_to_failsafe_timer:
    sequence:
      - service: timer.add
        entity_id: timer.clima_failsafe_general
        data:
          duration: '01:00:00'

  switch_to_fan_only:
    sequence:
      - service: climate.set_hvac_mode
        entity_id: climate.aire_acondicionado
        data:
          hvac_mode: fan_only

  clima_turbo_cool:
    alias: "Clima: Modo Turbo Cool (5 min)"
    icon: mdi:weather-windy
    sequence:
      - choose:
          # Si hace más calor que el umbral configurado
          - conditions:
              - condition: numeric_state
                entity_id: sensor.sala_temp_interior
                above: input_number.clima_turbo_threshold
            sequence:
              # Fase 1: Turbo
              - service: climate.set_temperature
                target:
                  entity_id: climate.aire_acondicionado
                data:
                  temperature: 20
                  hvac_mode: cool
              - service: climate.set_fan_mode
                target:
                  entity_id: climate.aire_acondicionado
                data:
                  fan_mode: high
              - delay: '00:05:00'
              # Fase 2: Normalización
              - service: climate.set_temperature
                target:
                  entity_id: climate.aire_acondicionado
                data:
                  temperature: 24
              - service: climate.set_fan_mode
                target:
                  entity_id: climate.aire_acondicionado
                data:
                  fan_mode: auto
        default:
          # Si no hace tanto calor, encender directo en modo normal
          - service: climate.turn_on
            target:
              entity_id: climate.aire_acondicionado
          - service: climate.set_temperature
            target:
              entity_id: climate.aire_acondicionado
            data:
              temperature: 24
          - service: climate.set_fan_mode
            target:
              entity_id: climate.aire_acondicionado
            data:
              fan_mode: auto

# ================================================================================
# == AUTOMATIONS: El cerebro del sistema
# ================================================================================

automation:
  # --- AUTOMATIZACIÓN 00: Maneja los modos forzados desde el input_select ---
  - id: clima_00_modo_forzado
    alias: "Clima - 00 - Modo Forzado (Encendido/Apagado)"
    trigger:
      - platform: state
        entity_id: input_select.modo_clima
    condition:
      - condition: state
        entity_id: input_boolean.smart_climate
        state: 'on'
    action:
      - choose:
          - conditions:
              - condition: state
                entity_id: input_select.modo_clima
                state: "Forzado Encendido"
            sequence:
              - service: climate.turn_on
                target:
                  entity_id: climate.aire_acondicionado
          - conditions:
              - condition: state
                entity_id: input_select.modo_clima
                state: "Forzado Apagado"
            sequence:
              - service: script.turn_on
                target:
                  entity_id: script.clima_forzar_apagado

  # --- AUTOMATIZACIÓN 01: Smart Inverter Follow Me (Ajuste Dinámico) ---
  - id: clima_01_smart_inverter_adjust
    alias: "Clima - 01 - Smart Inverter Follow Me"
    description: "Ajusta el setpoint del AC basándose en la temperatura real de la sala para mantener confort sin apagar el equipo."
    mode: restart
    trigger:
      - platform: state
        entity_id: sensor.sala_temp_interior
        for: "00:05:00" # Evitar oscilaciones rápidas
      - platform: time_pattern
        minutes: "/15" # Check de seguridad cada 15 min
    condition:
      - condition: state
        entity_id: input_boolean.smart_climate
        state: 'on'
      - condition: state
        entity_id: input_select.modo_clima
        state: "Automático"
      - condition: state
        entity_id: climate.aire_acondicionado
        state: 
          - 'cool'
          - 'heat'
          - 'auto'
      - condition: state
        entity_id: person.hernan
        state: 'home'
    action:
      - variables:
          current_temp: "{{ states('sensor.sala_temp_interior') | float }}"
          target_temp: "{{ 24 }}" # O usar input_number si existiera
          current_setpoint: "{{ state_attr('climate.aire_acondicionado', 'temperature') | float }}"
      - choose:
          # Si hace más calor que el objetivo (+0.5), bajamos el setpoint para "empujar" el frío
          - conditions: "{{ current_temp > target_temp + 0.5 }}"
            sequence:
              - service: climate.set_temperature
                target:
                  entity_id: climate.aire_acondicionado
                data:
                  temperature: "{{ [current_setpoint - 1, 18] | max }}"
          
          # Si hace más frío que el objetivo (-0.5), subimos el setpoint para suavizar
          - conditions: "{{ current_temp < target_temp - 0.5 }}"
            sequence:
              - service: climate.set_temperature
                target:
                  entity_id: climate.aire_acondicionado
                data:
                  temperature: "{{ [current_setpoint + 1, 28] | min }}"

  # --- AUTOMATIZACIÓN 02: Apagado por ausencia prolongada ---
  - id: clima_02_apagar_por_ausencia
    alias: "Clima - 02 - Apagar por Ausencia"
    trigger:
      - platform: state
        entity_id: person.hernan
        to: 'not_home'
        for:
          minutes: "{{ states('input_number.delay_ausencia_minutos') | int }}"
    condition:
      - condition: state
        entity_id: input_boolean.smart_climate
        state: 'on'
      - condition: state
        entity_id: input_select.modo_clima
        state: 'Automático'
    action:
      - service: script.turn_on
        target:
          entity_id: script.clima_forzar_apagado

  # --- AUTOMATIZACIÓN 03: Apagado al llegar a la oficina ---
  - id: clima_03_apagar_al_llegar_a_la_oficina
    alias: "Clima - 03 - Apagar al Llegar a la Oficina"
    trigger:
      - platform: state
        entity_id: person.hernan
        to: 'oficina'
        for:
          minutes: "{{ states('input_number.delay_oficina_minutos') | int }}"
    condition:
      - condition: state
        entity_id: input_boolean.smart_climate
        state: 'on'
      - condition: state
        entity_id: input_select.modo_clima
        state: 'Automático'
    action:
      - service: script.turn_on
        target:
          entity_id: script.clima_forzar_apagado

  # --- AUTOMATIZACIÓN 04: Iniciar Failsafe de 2 Horas ---
  - id: clima_04_iniciar_failsafe_de_2_horas
    alias: "Clima - 04 - Iniciar Failsafe de 2 Horas"
    trigger:
      - platform: state
        entity_id: climate.aire_acondicionado
        from: 'off'
    action:
      - service: timer.start
        target:
          entity_id: timer.clima_failsafe_general

  # --- AUTOMATIZACIÓN 04b: cancelar Failsafe de 2 Horas ---
  - id: clima_04_cancelar_failsafe_de_2_horas
    alias: "Clima - 04 - cancelar Failsafe de 2 Horas"
    trigger:
      - platform: state
        entity_id: climate.aire_acondicionado
        to: 'off'
    action:
      - service: timer.cancel
        target:
          entity_id: timer.clima_failsafe_general

  # --- AUTOMATIZACIÓN 05: Ejecutar Failsafe de 2 Horas ---
  - id: clima_05_ejecutar_failsafe_de_2_horas
    alias: "Clima - 05 - Ejecutar Failsafe de 2 Horas"
    trigger:
      - platform: event
        event_type: timer.finished
        event_data:
          entity_id: timer.clima_failsafe_general
    action:
      - choose:
          # Si el failsafe de medios está activo Y hay algo reproduciéndose -> Reiniciar Timer
          - conditions:
              - condition: state
                entity_id: input_boolean.clima_failsafe_media_player
                state: 'on'
              - condition: state
                entity_id: media_player.televisor_living
                state: 'playing'
            sequence:
              - service: timer.start
                target:
                  entity_id: timer.clima_failsafe_general
        default:
          # Si no -> Apagar
          - service: script.turn_on
            target:
              entity_id: script.clima_forzar_apagado

  # --- AUTOMATIZACIÓN 06: Finalización de Timer Preset ---
  - id: clima_06_finalizacion_de_timer_preset
    alias: "Clima - 06 - Finalización de Timer Preset"
    trigger:
      - platform: event
        event_type: timer.finished
        event_data:
          entity_id: timer.clima_preset
    action:
      - service: script.turn_on
        target:
          entity_id: script.clima_forzar_apagado

  # --- AUTOMATIZACIÓN 07: Pre-enfriado antes de llegar a casa ---
  - id: clima_07_pre_enfriado_antes_de_llegar
    alias: "Clima - 07 - Pre-enfriado antes de llegar a casa"
    trigger:
      - platform: time
        at: input_datetime.clima_schedule_1
      - platform: time
        at: input_datetime.clima_schedule_2
    condition:
      # Solo días de semana
      - condition: time
        weekday:
          - mon
          - tue
          - wed
          - thu
          - fri
      # El bypass general debe estar activo
      - condition: state
        entity_id: input_boolean.smart_climate
        state: 'on'
    action:
      - choose:
          # Opción 1: Usar temperatura custom
          - conditions:
              - condition: state
                entity_id: input_boolean.temp_pre_enfriado_custom
                state: 'on'
              - condition: numeric_state
                entity_id: sensor.sala_temp_interior
                above: input_number.temp_pre_enfriado_custom
            sequence:
              - service: climate.turn_on
                target:
                  entity_id: climate.aire_acondicionado
          # Opción 2: Usar temperatura por defecto
          - conditions:
              - condition: state
                entity_id: input_boolean.temp_pre_enfriado_custom
                state: 'off'
              - condition: numeric_state
                entity_id: sensor.sala_temp_interior
                above: input_number.temp_superior_encendido
            sequence:
              - service: climate.turn_on
                target:
                  entity_id: climate.aire_acondicionado

  # --- AUTOMATIZACIÓN 08: Iniciar Pausa Inteligente por Control Manual ---
  - id: clima_08_iniciar_pausa_inteligente_por_control_manual
    alias: "Clima - 08 - Iniciar Pausa Inteligente por Control Manual"
    trigger:
      - platform: state
        entity_id: climate.aire_acondicionado
    condition:
      # Esto verifica que el cambio fue hecho por un usuario y no por otra automatización
      - condition: template
        value_template: "{{ trigger.to_state.context.user_id is not none }}"
    action:
      - service: timer.start
        target:
          entity_id: timer.clima_control_manual
        data:
          duration: "{{ states('input_number.delay_control_manual_minutos') | int * 60 }}"

  # --- AUTOMATIZACIÓN 09: Failsafe corto al encender sin estar en casa ---
  - id: clima_09_failsafe_corto_stand_alone
    alias: "Clima - 09 - Failsafe corto al encender sin estar en casa"
    trigger:
      - platform: state
        entity_id: climate.aire_acondicionado
        from: 'off'
    condition:
      - condition: state
        entity_id: person.hernan
        state: 'not_home'
      - condition: state # Solo si no hay ya un preset corriendo
        entity_id: timer.clima_preset
        state: 'idle'
    action:
      - service: script.turn_on
        target:
          entity_id: script.clima_preset_20m

  # --- AUTOMATIZACIÓN 10: Trigger Manual Turbo Cool ---
  - id: clima_manual_turbo_trigger
    alias: "Clima - 10 - Trigger Manual Turbo Cool"
    trigger:
      - platform: state
        entity_id: input_button.clima_trigger_turbo
    action:
      - service: script.turn_on
        target:
          entity_id: script.clima_turbo_cool

# ================================================================================
# == AUTOMATIONS: Notificaciones (Cada una es independiente)
# ================================================================================

  - id: clima_notificacion_apagado_por_ausencia
    alias: "Clima - Notificación - Apagado por Ausencia"
    # Esta automatización está habilitada por defecto. 
    # Puedes deshabilitarla desde el dashboard si no quieres la notificación.
    trigger:
      # Se dispara cuando el script de forzar apagado es llamado
      - platform: event
        event_type: call_service
        event_data:
          domain: script
          service: clima_forzar_apagado
    condition:
      # Y la razón es que no estás en casa
      - condition: state
        entity_id: person.hernan
        state: 'not_home'
    action:
      - service: notify.hernan # <-- CAMBIA ESTO por tu servicio de notificación
        data:
          title: "❄️ Clima Inteligente"
          message: "El aire acondicionado se ha apagado por ausencia."

  - id: clima_notificacion_pre_enfriado_activado
    alias: "Clima - Notificación - Pre-enfriado Activado"
    trigger:
      - platform: state
        entity_id: automation.clima_07_pre_enfriado_antes_de_llegar
        from: 'off'
        to: 'on'
    action:
      - service: notify.hernan # <-- CAMBIA ESTO por tu servicio de notificación
        data:
          title: "❄️ Clima Inteligente"
          message: "Pre-enfriando la casa para tu llegada. Temperatura actual: {{ states('sensor.sala_temp_interior') }}°C"

  - id: clima_notificacion_failsafe_2_horas
    alias: "Clima - Notificación - Failsafe 2 Horas - 5 Minutos Antes"
    trigger:
      - platform: template
        value_template: "{{ state_attr('timer.clima_failsafe_general', 'remaining') | int <= 300 }}"
    condition:
      - condition: state
        entity_id: timer.clima_failsafe_general
        state: 'active'
    action:
      - service: notify.hernan # <-- CAMBIA ESTO por tu servicio de notificación
        data:
          title: "⚠️ Alerta de Clima"
          message: "El aire acondicionado se apagará en 5 minutos por seguridad."
          data:
            actions:
              - action: "add_hour"
                title: "Agregar 1 Hora"
              - action: "fan_only"
                title: "Modo Solo Ventilador"


  - id: clima_notificacion_action_add_hour
    alias: "Clima - Acción Notificación - Agregar Hora"
    trigger:
      - platform: event
        event_type: mobile_app_notification_action
        event_data:
          action: add_hour
    action:
      - service: script.add_hour_to_failsafe_timer

  - id: clima_notificacion_action_fan_only
    alias: "Clima - Acción Notificación - Modo Ventilador"
    trigger:
      - platform: event
        event_type: mobile_app_notification_action
        event_data:
          action: fan_only
    action:
      - service: script.switch_to_fan_only